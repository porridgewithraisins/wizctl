#! /usr/bin/env bash

set -eu

: "${WIZCTL_FILE:="$HOME/.wizzes"}"
: "${WIZCTL_SCENES_FILE:="$HOME/wizctl/scenes.txt"}"
: "${WIZCTL_COLORS_FILE:="$HOME/wizctl/colors.csv"}"
: "${WIZCTL_PORT:=38899}"
: "${WIZCTL_API_PACING:=0.5}"
: "${WIZ_CTL_ONLINE_ISWIZ:=0}"
: "${WIZCTL_DRY_RUN:=0}"
: "${WIZCTL_DEBUG:=0}"
: "${WIZCTL_DEFAULT_DIMMING:=75}"
: "${WIZCTL_DEFAULT_SPEED:=125}"
: "${WIZCTL_IFACE:="$(ip route show default | cut -d' ' -f5)"}"

test "$WIZCTL_DEBUG" = 2 && set -x

command -v nc >/dev/null && : "${WIZCTL_NC_IMPL:=nc}"
command -v ncat >/dev/null && : "${WIZCTL_NC_IMPL:=ncat}"
test -n "${WIZCTL_NC_IMPL:-}" || {
    echo "Cannot find netcat implementation. Please install nc/ncat or set NC_IMPL." >&2
    exit 1
}

__breakpoint(){
    while read -p"Debugging(Ctrl-d to exit)> " debugging_line
    do
        eval "$debugging_line"
    done
}

_iswiz() {
    prefix="$(echo "$1" | cut -c1-8 | tr a-z A-Z)"

    case "$prefix" in
        08:56:9B|44:4F:8E|98:77:D5|CC:40:85|D8:A0:11|A8:BB:50)
            return 0
            ;;
    esac

    _onlineiswiz() {
        vendor="$(curl -s "https://api.macvendors.com/$1")"
        sleep "$WIZCTL_API_PACING"
        test "$vendor" = WiZ
    }
    test "$WIZ_CTL_ONLINE_ISWIZ" = 1 && _onlineiswiz "$1" || return 1
}

_setstatemsg() {
    echo -n "{\"id\":1,\"method\":\"setState\",\"params\":{\"state\":$1}}"
}

_getstatemsg() {
    echo -n "{\"method\":\"getPilot\",\"params\":{}}"
}

_setscenemsg() {
   if test "$1" = "static"; then
       echo -n "{\"id\":1,\"method\":\"setPilot\",\"params\":{\"sceneId\":$2,\"dimming\":$3}}"
   else
       echo -n "{\"id\":1,\"method\":\"setPilot\",\"params\":{\"sceneId\":$2,\"dimming\":$3, \"speed\":$4}}"
   fi
}

_setcolormsg() {
    echo -n "{\"id\":1,\"method\":\"setPilot\",\"params\":{\"r\":$1,\"g\":$2,\"b\":$3,\"dimming\": $4}}"
}

_settempmsg() {
    echo -n "{\"id\":1,\"method\":\"setPilot\",\"params\":{\"temp\":$1,\"dimming\":$2}}"
}

_send_ip() {
    test "$WIZCTL_DRY_RUN" = 1 && echo Sending "$1" to "$2" >&2 && return 0
    READ_WAIT_INTERVAL=$(test "$WIZCTL_NC_IMPL" = "ncat" && echo 0 || echo .5)
    { echo "$1"; sleep "$READ_WAIT_INTERVAL"; } | "$WIZCTL_NC_IMPL" -uw1 ${3:+$3} "$2" "$WIZCTL_PORT"; echo
}

_scan() {
    exec 8>/tmp/wizctl.scan.lock
    flock -n 8 || { echo "scan already running"; return 1; }

    brd="$(ip -4 addr show dev "$WIZCTL_IFACE" | awk '/brd/ {print $4}')"
    _send_ip "$(_getstatemsg)" "$brd" '-b'
}

_send_mac() {
    for mac in $2; do
        if ! ip neigh | grep -qF "$mac"; then
            _scan || return 1
            break
        fi
    done


    for mac in $2; do
        ip="$(ip neigh | grep -F "$mac" | cut -d' ' -f1)"
        _send_ip "$1" "$ip"
    done
}

_getmacs() {
    cat "$WIZCTL_FILE" | grep -w "$1" | cut -d' ' -f1
}

scan() { _scan; }

list() {
    wizzes=$(ip neigh | cut -d' ' -f1,5 |
        while read -r ip mac; do _iswiz "$mac" && echo "$mac $ip"; done |
        tee "$WIZCTL_FILE".tmp
    ) # mac ip

    gum style \
    "Found these WiZ bulbs:
    $wizzes
    "
}

setup(){
    exec 9>/tmp/wizctl.setup.lock
    flock 9 || { echo "Setup already running"; return 1; }

    if test "$#" -ge 2 && test "$1" = "--manual"; then
        echo "Write the mac address, name and room into the $WIZCTL_FILE file"
    fi

    export $(compgen -v | grep '^WIZCTL')
    export -f $(declare -F | awk '{print $3}')

    gum spin --title "Discovering bulbs..." --show-output -- bash -c 'scan && list'

    gum style "The next step will temporarily set ALL bulbs to 'red' then change them to 'blue' one by one so you can tell me their names and their rooms. Then they will turn green once setup."

    gum confirm "Continue?" || return 1

    while read -r _ ip; do
        result="$(_send_ip "$(_setcolormsg 255 0 0 92)" "$ip")"
    done < "$WIZCTL_FILE.tmp"

    if ! echo "$result" | grep -q '{"success":true}' || ! gum confirm "Are all of them red?";  then
       echo "Manual flow here TODO"
       exit 1
    fi

    cat "$WIZCTL_FILE".tmp | while read -r mac ip; do
        if test -f "$WIZCTL_FILE" && line="$(cat "$WIZCTL_FILE" | grep "$mac")"; then
            gum confirm "Already exists in file: $line re-setup?" || continue
            tmp="$(mktemp)"
            { cat "$WIZCTL_FILE" | grep -vF "$mac" || true; } > "$tmp"
            mv "$tmp" "$WIZCTL_FILE"
        fi

        if ! _send_ip "$(_setcolormsg 0 0 255 92)" "$ip" | grep -q '{"success":true}'; then
            gum confirm "Failed to set to blue, set up rest anyway?" && continue || return 1
        fi
        name=$(gum input --placeholder "What's the name of the blue device?")
        room=$(gum input --placeholder "What's the room of the blue device?")
        echo "$mac" "$name" "$room" >> "$WIZCTL_FILE"
        if ! _send_ip "$(_setcolormsg 0 255 0 92)" "$ip" | grep -q '{"success":true}'; then
            gum confirm "Failed to set to green, continue anyways?" && continue || return 1
        fi
    done

    rm "$WIZCTL_FILE".tmp
}

status() {
    macs="$(_getmacs "$1")" || return 1
    result="$(_send_mac "$(_getstatemsg)" "$macs")"
    if ! echo "$result" | grep -q '"method":"getPilot"'; then
        echo "FAILED: $result"
    else
        echo "SUCCESS: $result"
    fi
}


on() {
    macs="$(_getmacs "$1")" || return 1
    result="$(_send_mac "$(_setstatemsg true)" "$macs")"
    if ! echo "$result" | grep -q '{"success":true}'; then
        echo "FAILED: $result"
    else
        echo "SUCCESS: $result"
    fi
}

off() {
    macs="$(_getmacs "$1")" || return 1
    result="$(_send_mac "$(_setstatemsg false)" "$macs")"
    if ! echo "$result" | grep -q '{"success":true}'; then
        echo "FAILED: $result"
    else
        echo "SUCCESS: $result"
    fi
}

temp() {
    macs="$(_getmacs "$1")" || return 1

    if test "$#" -ge 2; then
        temp="$2"
        dimming="${3:-$WIZCTL_DEFAULT_DIMMING}"
    else
        temp="$(gum input --placeholder "2200-6200 (suggested 3000)" --header "Temperature")"
        while ! test -n "$temp" || ! test "$temp" -eq "$temp" 2>/dev/null || test "$temp" -lt 2200 || test "$temp" -gt 6200; do
            temp="$(gum input --placeholder "2200-6200 (suggested 3000)" --header "Invalid temperature")"
        done

        dimming="$(gum input --value "$WIZCTL_DEFAULT_DIMMING" --placeholder "10-100" --header "Brightness")"
        while ! test -n "$dimming" || ! test "$dimming" -eq "$dimming" 2>/dev/null || test "$dimming" -lt 10 || test "$dimming" -gt 100; do
            dimming="$(gum input --value "$WIZCTL_DEFAULT_DIMMING" --placeholder "10-100" --header "Invalid brightness")"
        done
    fi

    result="$(_send_mac "$(_settempmsg "$temp" "$dimming")" "$macs")"
    if ! echo "$result" | grep -q '{"success":true}'; then
        echo "FAILED: $result"
    else
        echo "SUCCESS: $result"
    fi
}

color() {
    macs="$(_getmacs "$1")" || return 1

    if test "$#" -ge 2; then
        color="$2"
        parsed="$(colorinspector "$color")"
        dimming="${3:-$WIZCTL_DEFAULT_DIMMING}"
    else
        color="$({ cat "$WIZCTL_COLORS_FILE" | cut -d, -f1 | xargs -n1 colorinspector --name; } | gum filter --no-strip-ansi --no-strict --height 25 --header "Enter color(255,255,0 or rgb(1,2,3) or red or #ff0000 or #FF0000)")"
        parsed="$(colorinspector "$color")"
        gum style "Using $parsed"
        dimming="$(gum input --value "$WIZCTL_DEFAULT_DIMMING" --placeholder "10-100" --header "Brightness")"
        while ! test -n "$dimming" || ! test "$dimming" -eq "$dimming" 2>/dev/null || test "$dimming" -lt 10 || test "$dimming" -gt 100; do
            dimming="$(gum input --value "$WIZCTL_DEFAULT_DIMMING" --placeholder "10-100" --header "Invalid brightness")"
        done
    fi

    read -r r g b <<< "$(echo "$parsed" | cut -d' ' -f5 | cut -d'(' -f2 | cut -d')' -f1 | tr , ' ')"

    result="$(_send_mac "$(_setcolormsg "$r" "$g" "$b" "$dimming")" "$macs")"
    if ! echo "$result" | grep -q '{"success":true}'; then
        echo "FAILED: $result"
    else
        echo "SUCCESS: $result"
    fi
}

scene() {
    macs="$(_getmacs "$1")" || return 1

    if test "$#" -ge 2; then
        name="$2"
        type="$(cat "$WIZCTL_SCENES_FILE" | grep " $name$" | cut -d' ' -f2)"
        id="$(cat "$WIZCTL_SCENES_FILE" | grep " $name$" | cut -d' ' -f1)"
        dimming="${3:-$WIZCTL_DEFAULT_DIMMING}"
        speed="${4:-$WIZCTL_DEFAULT_SPEED}"
    else
        chosen=$(cat "$WIZCTL_SCENES_FILE" |
        sort -rk2 |
        awk '{
            t=$2;$1=$2=""; sub(/^ +/,""); print $0 " \033[2m" t "\033[0m"
        }' |
        gum filter --no-strip-ansi --height 15 --header "Choose scene"    )
        name=$(echo "$chosen" | rev | cut -d' ' -f2- | rev)
        type=$(echo "$chosen" | rev | cut -d' ' -f1 | rev)
        id="$(cat "$WIZCTL_SCENES_FILE" | grep "$type $name$" | cut -d' ' -f1)"

        dimming="$(gum input --value "$WIZCTL_DEFAULT_DIMMING" --placeholder "10-100" --header "Brightness")"
        while ! test -n "$dimming" || ! test "$dimming" -eq "$dimming" 2>/dev/null || test "$dimming" -lt 10 || test "$dimming" -gt 100; do
            dimming="$(gum input --value "$WIZCTL_DEFAULT_DIMMING" --placeholder "10-100" --header "Invalid brightness")"
        done

        speed="$WIZCTL_DEFAULT_SPEED"
        if test "$type" = dynamic; then
            speed="$(gum input --value "$WIZCTL_DEFAULT_SPEED" --placeholder "10-200" --header "Speed")"
            while ! test -n "$speed" || ! test "$speed" -eq "$speed" 2>/dev/null || test "$speed" -lt 10 || test "$speed" -gt 200; do
                speed="$(gum input --value "$WIZCTL_DEFAULT_SPEED" --placeholder "10-200" --header "Invalid speed")"
            done
        fi

    fi

    result=$(_send_mac "$(_setscenemsg "$type" "$id" "$dimming" "$speed")" "$macs")
    if ! echo "$result" | grep -q '{"success":true}'; then
        echo "FAILED: $result"
    else
        echo "SUCCESS: $result"
    fi
}

profile() {
    file="$1"
    while read -r line; do
        if test "$line" != 'wait'; then
            eval "$line" &
        else
            wait
        fi
    done < <(cat "$file" | grep -v '^#' | grep .)
    wait
}

preview() {
    kind="$1"
    target="$2"
    shift 2

    case "$kind" in
        scene)
            awk '{
                t=$2
                $1=$2=""
                sub(/^ +/, "")
                print
            }' "$WIZCTL_SCENES_FILE" |
            gum filter --height 15 --preview "
                wizctl scene '$target' '{}' $* >/dev/null 2>&1 &
            "
            ;;

        temp)
            printf '%s\n' 2200 2700 3000 3500 4000 5000 6200 |
            gum filter --height 15 --preview '
                wizctl temp '"$target"' '{}' '"$*"' >/dev/null 2>&1 &
            '
            ;;

        color)
            cut -d, -f1 "$WIZCTL_COLORS_FILE" |
            gum filter --height 15 --preview '
                wizctl color '"$target"' '{}' '"$*"' >/dev/null 2>&1 &
            '
            ;;
    esac
}


usage() {
    cat <<EOF
Commands:
  setup
  on <device|room>
  off <device|room>
  temp <device|room> [temp] [brightness=$WIZCTL_DEFAULT_DIMMING]
  color <device|room> [color] [brightness=$WIZCTL_DEFAULT_DIMMING]
  scene <device|room> [scene] [brightness=$WIZCTL_DEFAULT_DIMMING] [speed=$WIZCTL_DEFAULT_SPEED]
  profile <file>
  preview <temp|color|scene|profile> <device|room> [brightness=$WIZCTL_DEFAULT_DIMMING] [speed=$WIZCTL_DEFAULT_SPEED]

Speed can be provided if the scene is dynamic
EOF
}


gum style "WiZ CLI"
cmd="${1:-usage}"
shift || true
"$cmd" "$@"
